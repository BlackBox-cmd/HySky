# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Hypixel API key used for server-side requests
HYPIXEL_API_KEY=your_hypixel_api_key_here

# MongoDB connection string for linked accounts, alert subscriptions, and guild config
MONGODB_URI=mongodb://127.0.0.1:27017/hysky

# Footer shown at the bottom of embeds
FOOTER_TEXT="HySky Bot | Made by Mr_Freak_cmd | v1.1.0"

# Optional: only set this if you want to clear old guild-specific commands
GUILD_ID=

# Uptime Kuma push URL for heartbeat monitoring
UPTIME_KUMA_URL=https://status.freakcloud.tk/api/push/CkXep2gTIV55jEaZ2mizfXqWWJaZBwz6?status=up&msg=OK&ping=

# Uptime Kuma heartbeat interval in seconds (default is 30)
UPTIME_KUMA_INTERVAL=30
